---

---

<section id="contact" class="contact section-padding">
  <div class="container">
    <div class="contact-header reveal">
      <span class="section-label">CONTACT</span>
      <h2 class="contact-title">
        <span class="gradient-text">お問い合わせ</span>
      </h2>
      <p class="contact-lead">
        出展・協賛・ボランティア・その他ご質問等、お気軽にお問い合わせください。
      </p>
    </div>

    <div class="contact-card reveal">
      <form class="contact-form" id="contact-form">
        <input type="hidden" name="access_key" value="d5811f05-a355-4328-8121-071fda251336" />
        <input type="hidden" name="from_name" value="NARAHA VERO BASE お問い合わせ" />
        <input type="checkbox" name="botcheck" style="display:none" />

        <div class="form-group">
          <label for="contact-name" class="form-label">お名前 <span class="required">*</span></label>
          <input
            type="text"
            id="contact-name"
            name="name"
            class="form-input"
            placeholder="山田 太郎"
            required
          />
        </div>

        <div class="form-group">
          <label for="contact-subject" class="form-label">件名 <span class="required">*</span></label>
          <input
            type="text"
            id="contact-subject"
            name="subject"
            class="form-input"
            placeholder="お問い合わせの件名を入力"
            required
          />
        </div>

        <div class="form-group">
          <label for="contact-email" class="form-label">メールアドレス <span class="required">*</span></label>
          <input
            type="email"
            id="contact-email"
            name="email"
            class="form-input"
            placeholder="example@email.com"
            required
          />
        </div>

        <div class="form-group">
          <label for="contact-message" class="form-label">本文 <span class="required">*</span></label>
          <textarea
            id="contact-message"
            name="message"
            class="form-input form-textarea"
            placeholder="お問い合わせ内容をご入力ください"
            rows="6"
            required
          ></textarea>
        </div>

        <div class="form-actions">
          <button type="submit" class="form-submit" id="contact-submit">
            <span class="submit-icon">📩</span>
            送信する
          </button>
        </div>

        <div class="form-message" id="form-message"></div>
      </form>

    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const messageEl = document.getElementById('form-message');
    const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement;

    if (form && messageEl && submitBtn) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();

        submitBtn.disabled = true;
        submitBtn.textContent = '送信中...';
        messageEl.className = 'form-message';

        const formData = new FormData(form);
        const response = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          body: formData,
        });
        const data = await response.json();

        if (data.success) {
          messageEl.textContent = 'お問い合わせを受け付けました。ありがとうございます。';
          messageEl.className = 'form-message success';
          form.reset();
        } else {
          messageEl.textContent = '送信に失敗しました。時間をおいて再度お試しください。';
          messageEl.className = 'form-message error';
        }

        submitBtn.disabled = false;
        submitBtn.innerHTML = '<span class="submit-icon">📩</span> 送信する';
      });
    }
  });
</script>

<style>
  .contact {
    background: var(--color-sand);
  }

  .contact-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-label {
    display: inline-block;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    color: var(--color-sunset);
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .section-label::before,
  .section-label::after {
    content: '';
    display: inline-block;
    width: 30px;
    height: 1px;
    background: var(--color-sunset);
    vertical-align: middle;
    margin: 0 1rem;
    opacity: 0.5;
  }

  .contact-title {
    font-size: clamp(1.6rem, 4.5vw, 2.8rem);
    color: var(--color-dark);
    line-height: 1.5;
    margin-bottom: 1rem;
  }

  .contact-lead {
    font-size: 1rem;
    color: var(--color-gray-500);
    max-width: 600px;
    margin: 0 auto;
  }

  .contact-card {
    max-width: 640px;
    margin: 0 auto;
    background: var(--color-white);
    border-radius: var(--radius-card);
    padding: 2.5rem 2rem;
    box-shadow: var(--shadow-card);
  }

  @media (min-width: 768px) {
    .contact-card {
      padding: 3rem 3rem;
    }
  }

  .form-group {
    margin-bottom: 1.5rem;
  }

  .form-label {
    display: block;
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-dark);
    margin-bottom: 0.5rem;
  }

  .required {
    color: var(--color-coral);
    font-size: 0.75rem;
  }

  .form-input {
    width: 100%;
    padding: 0.9rem 1.2rem;
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--color-dark);
    background: var(--color-gray-100);
    border: 2px solid transparent;
    border-radius: 12px;
    outline: none;
    transition: all 0.3s ease;
  }

  .form-input::placeholder {
    color: var(--color-gray-400);
  }

  .form-input:focus {
    background: var(--color-white);
    border-color: var(--color-ocean);
    box-shadow: 0 0 0 4px rgba(0, 180, 216, 0.1);
  }

  .form-textarea {
    resize: vertical;
    min-height: 120px;
  }

  .form-actions {
    text-align: center;
    margin-top: 2rem;
  }

  .form-submit {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 3rem;
    background: linear-gradient(135deg, var(--color-sunset), var(--color-coral));
    color: var(--color-white);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1rem;
    border: none;
    border-radius: var(--radius-pill);
    cursor: pointer;
    transition: all 0.4s ease;
    box-shadow: 0 4px 20px rgba(255, 107, 53, 0.3);
    letter-spacing: 0.05em;
  }

  .form-submit:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 30px rgba(255, 107, 53, 0.5);
  }

  .form-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  .submit-icon {
    font-size: 1.1rem;
  }

  .form-message {
    text-align: center;
    margin-top: 1.5rem;
    font-size: 0.85rem;
    font-weight: 500;
    padding: 0.75rem 1rem;
    border-radius: 10px;
    display: none;
  }

  .form-message.success {
    display: block;
    color: #2D8F4E;
    background: rgba(45, 143, 78, 0.1);
  }

  .form-message.error {
    display: block;
    color: var(--color-coral);
    background: rgba(255, 107, 107, 0.1);
  }

  .contact-alt {
    text-align: center;
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-gray-200);
  }

  .contact-alt-text {
    font-size: 0.8rem;
    color: var(--color-gray-400);
    margin-bottom: 0.5rem;
  }

  .contact-email-link {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-ocean);
    transition: color 0.3s ease;
  }

  .contact-email-link:hover {
    color: var(--color-ocean-deep);
  }
</style>
