---
const highlights = [
  {
    icon: '🌊',
    title: '太平洋を一望',
    desc: '天神岬スポーツ公園は太平洋に面した絶好のロケーション。水平線に沈む夕日は圧巻。',
  },
  {
    icon: '🌿',
    title: '広大な芝生エリア',
    desc: 'テントサイトに最適な広い芝生。潮風を感じながらの開放的なキャンプ体験。',
  },
  {
    icon: '♨️',
    title: '周辺施設も充実',
    desc: '温泉、道の駅、地元グルメ。楢葉の魅力を存分に味わえる環境が整っています。',
  },
  {
    icon: '🚴',
    title: 'ツールド福島連携',
    desc: '同時開催の「ツールド福島」と連携し、楢葉町をサイクリストの聖地に。',
  },
];
---

<section id="venue" class="venue section-padding">
  <div class="container">
    <div class="venue-header reveal">
      <span class="section-label">VENUE</span>
      <h2 class="venue-title">
        <span class="gradient-text">天神岬スポーツ公園</span><br>
        絶景のベースキャンプ
      </h2>
      <p class="venue-location">
        <span class="venue-pin">📍</span>
        福島県双葉郡楢葉町 天神岬スポーツ公園
      </p>
    </div>

    <!-- Map placeholder with gradient -->
    <div class="venue-map-container reveal">
      <div class="venue-map">
        <div class="map-placeholder">
          <div class="map-content">
            <span class="map-icon">🗺️</span>
            <p class="map-text">天神岬スポーツ公園</p>
            <p class="map-sub">福島県双葉郡楢葉町</p>
            <a 
              href="https://maps.google.com/?q=天神岬スポーツ公園+楢葉町" 
              target="_blank" 
              rel="noopener noreferrer"
              class="map-link"
            >
              Google Mapで見る →
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Highlights grid -->
    <div class="venue-highlights">
      {highlights.map((h, i) => (
        <div class={`highlight-card reveal delay-${(i + 1) * 100}`}>
          <span class="highlight-icon">{h.icon}</span>
          <h3 class="highlight-title">{h.title}</h3>
          <p class="highlight-desc">{h.desc}</p>
        </div>
      ))}
    </div>

    <!-- Tour de Fukushima synergy -->
    <div class="synergy-banner reveal">
      <div class="synergy-content">
        <div class="synergy-badge">🤝 COLLABORATION</div>
        <h3 class="synergy-title">ツールド福島 × NARAHA VERO BASE</h3>
        <p class="synergy-desc">
          日本屈指のロングライドイベント「ツールド福島」との同時開催。
          レースの興奮と、NVBのCHILLな雰囲気が融合する、唯一無二の週末に。
        </p>
      </div>
    </div>

    <!-- Access Information -->
    <div class="access-section reveal">
      <h3 class="access-heading">
        <span class="gradient-text">アクセス</span>
      </h3>
      <div class="access-grid">
        <div class="access-card">
          <span class="access-icon">🚗</span>
          <h4 class="access-method">お車でお越しの方</h4>
          <p class="access-detail">
            常磐自動車道「広野IC」より約10分。<br>
            会場内に無料駐車場あり（約200台）。<br>
            ※ 混雑時は臨時駐車場をご案内します。
          </p>
        </div>
        <div class="access-card">
          <span class="access-icon">🚃</span>
          <h4 class="access-method">電車でお越しの方</h4>
          <p class="access-detail">
            JR常磐線「竜田駅」下車、車で約10分。<br>
            東京駅から特急ひたちで約2時間半。<br>
            ※ 駅からのシャトルバス運行予定。
          </p>
        </div>
        <div class="access-card">
          <span class="access-icon">🚌</span>
          <h4 class="access-method">バスでお越しの方</h4>
          <p class="access-detail">
            いわき駅前より路線バスで約50分。<br>
            イベント当日は主要駅から<br>
            シャトルバスの運行を予定しています。
          </p>
        </div>
      </div>
      <div class="access-address">
        <p>📮 〒979-0513 福島県双葉郡楢葉町北田天神原30</p>
        <p>🅿️ 無料駐車場あり（約200台）</p>
      </div>
    </div>
  </div>
</section>

<style>
  .venue {
    background: var(--color-white);
    position: relative;
  }

  .venue-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-label {
    display: inline-block;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    color: var(--color-sunset);
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .section-label::before,
  .section-label::after {
    content: '';
    display: inline-block;
    width: 30px;
    height: 1px;
    background: var(--color-sunset);
    vertical-align: middle;
    margin: 0 1rem;
    opacity: 0.5;
  }

  .venue-title {
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    color: var(--color-dark);
    line-height: 1.4;
    margin-bottom: 1rem;
  }

  .venue-location {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1rem;
    color: var(--color-gray-500);
    background: var(--color-gray-100);
    padding: 0.5rem 1.5rem;
    border-radius: var(--radius-pill);
  }

  .venue-map-container {
    margin-bottom: 3rem;
  }

  .venue-map {
    border-radius: var(--radius-card);
    overflow: hidden;
    box-shadow: var(--shadow-card);
  }

  .map-placeholder {
    height: 300px;
    background: linear-gradient(135deg, var(--color-dark-soft), var(--color-dark-muted), var(--color-ocean-deep));
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .map-placeholder::before {
    content: '';
    position: absolute;
    inset: 0;
    background: 
      radial-gradient(circle at 30% 70%, rgba(0, 180, 216, 0.2) 0%, transparent 50%),
      radial-gradient(circle at 70% 30%, rgba(255, 107, 53, 0.15) 0%, transparent 50%);
  }

  .map-content {
    text-align: center;
    position: relative;
    z-index: 1;
    color: var(--color-white);
  }

  .map-icon {
    font-size: 3rem;
    display: block;
    margin-bottom: 1rem;
  }

  .map-text {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
  }

  .map-sub {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 1rem;
  }

  .map-link {
    display: inline-block;
    padding: 0.5rem 1.5rem;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: var(--color-white);
    border-radius: var(--radius-pill);
    font-size: 0.85rem;
    font-weight: 500;
    transition: all 0.3s ease;
  }

  .map-link:hover {
    background: rgba(255, 255, 255, 0.25);
    transform: translateY(-2px);
  }

  .venue-highlights {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    margin-bottom: 3rem;
  }

  @media (min-width: 768px) {
    .venue-highlights {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }
  }

  @media (min-width: 1024px) {
    .venue-highlights {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .highlight-card {
    background: var(--color-sand);
    border-radius: var(--radius-card);
    padding: 2rem 1.5rem;
    text-align: center;
    transition: all 0.3s ease;
  }

  .highlight-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-card);
    background: var(--color-white);
  }

  .highlight-icon {
    font-size: 2.5rem;
    display: block;
    margin-bottom: 1rem;
  }

  .highlight-title {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-dark);
    margin-bottom: 0.5rem;
  }

  .highlight-desc {
    font-size: 0.8rem;
    color: var(--color-gray-500);
    line-height: 1.7;
  }

  /* Synergy Banner */
  .synergy-banner {
    background: linear-gradient(135deg, var(--color-dark), var(--color-dark-soft));
    border-radius: var(--radius-card);
    padding: 2.5rem 2rem;
    position: relative;
    overflow: hidden;
  }

  .synergy-banner::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 300px;
    height: 300px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-sunset), var(--color-ocean));
    opacity: 0.1;
    filter: blur(40px);
  }

  .synergy-content {
    position: relative;
    z-index: 1;
    text-align: center;
  }

  .synergy-badge {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    color: var(--color-ocean-light);
    background: rgba(0, 180, 216, 0.15);
    padding: 0.35rem 1rem;
    border-radius: var(--radius-pill);
    margin-bottom: 1rem;
  }

  .synergy-title {
    font-size: clamp(1.2rem, 3vw, 1.5rem);
    color: var(--color-white);
    margin-bottom: 1rem;
  }

  .synergy-desc {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.8;
    max-width: 600px;
    margin: 0 auto;
  }

  /* Access Section */
  .access-section {
    margin-top: 3rem;
  }

  .access-heading {
    font-size: clamp(1.3rem, 3vw, 1.8rem);
    text-align: center;
    margin-bottom: 2rem;
  }

  .access-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  @media (min-width: 768px) {
    .access-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
  }

  .access-card {
    background: var(--color-sand);
    border-radius: var(--radius-card);
    padding: 1.75rem 1.5rem;
    text-align: center;
    transition: all 0.3s ease;
  }

  .access-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-card);
    background: var(--color-white);
  }

  .access-icon {
    font-size: 2.2rem;
    display: block;
    margin-bottom: 0.75rem;
  }

  .access-method {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-dark);
    margin-bottom: 0.75rem;
  }

  .access-detail {
    font-size: 0.8rem;
    color: var(--color-gray-500);
    line-height: 1.8;
  }

  .access-address {
    text-align: center;
    padding: 1.25rem;
    background: var(--color-gray-100);
    border-radius: var(--radius-card);
  }

  .access-address p {
    font-size: 0.85rem;
    color: var(--color-gray-500);
    line-height: 1.8;
  }
</style>
