---
const highlights = [
  {
    photo: '/images/venue-ocean-view.jpg',
    title: '太平洋を一望',
    desc: '天神岬スポーツ公園は太平洋に面した絶好のロケーション。水平線に沈む夕日は圧巻。',
  },
  {
    photo: '/images/venue-lawn.jpg',
    title: '広大な芝生エリア',
    desc: 'テントサイトに最適な広い芝生。潮風を感じながらの開放的なキャンプ体験。',
  },
  {
    photo: '/images/venue-facilities.jpg',
    title: '周辺施設も充実',
    desc: '敷地内の温浴施設は大会期間中無料で利用可能。道の駅や地元グルメも楽しめます。',
  },
  {
    photo: '/images/venue-cycling.jpg',
    title: 'ツール・ド・ふくしま連携',
    desc: '同時開催の「ツール・ド・ふくしま」と連携し、楢葉町をサイクリストの聖地に。',
  },
  {
    photo: '/images/venue-bonfire-night.jpg',
    title: '焚き火トーク × 花火',
    desc: '夜は焚き火を囲んだトークショーを開催。そしてクライマックスには花火が夜空を彩ります。泊まった人だけの特別な時間。',
  },
];
---

<section id="venue" class="venue section-padding">
  <div class="container">
    <div class="venue-header reveal">
      <span class="section-label">VENUE</span>
      <h2 class="venue-title">
        <span class="gradient-text">天神岬スポーツ公園</span><br>
        絶景のベースキャンプ
      </h2>
      <p class="venue-location">
        <span class="venue-pin">📍</span>
        福島県双葉郡楢葉町 天神岬スポーツ公園
      </p>
    </div>

    <!-- Google Map -->
    <div class="venue-map-container reveal">
      <div class="venue-map">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3175.0!2d141.015!3d37.2685!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x60212107de83cbc1%3A0x8c6e88a3a498c54f!2z5aSp56We5bKs44K544Od44O844OE5YWs5ZyS!5e0!3m2!1sja!2sjp!4v1774165743951!5m2!1sja!2sjp"
          width="100%"
          height="400"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="天神岬スポーツ公園 マップ"
        ></iframe>
      </div>
    </div>

    <!-- Highlights grid -->
    <div class="venue-highlights">
      {highlights.map((h, i) => (
        <div class={`highlight-card reveal delay-${(i + 1) * 100}`}>
          <div class="highlight-photo-wrap">
            {h.photo ? (
              <img src={h.photo} alt={h.title} class="highlight-photo" loading="lazy" />
            ) : (
              <div class="highlight-emoji-placeholder">
                <span>{h.emoji}</span>
              </div>
            )}
          </div>
          <div class="highlight-body">
            <h3 class="highlight-title">{h.title}</h3>
            <p class="highlight-desc">{h.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Tour de Fukushima synergy -->
    <div class="synergy-banner reveal">
      <div class="synergy-content">
        <div class="synergy-badge">🤝 COLLABORATION</div>
        <h3 class="synergy-title">ツール・ド・ふくしま × NARAHA VERO BASE</h3>
        <p class="synergy-desc">
          日本屈指のロングライドイベント「ツール・ド・ふくしま」との同時開催。
          レースの興奮と、NVBのCHILLな雰囲気が融合する、唯一無二の週末に。
        </p>
      </div>
    </div>

    <!-- Access Information -->
    <div class="access-section reveal">
      <h3 class="access-heading">
        <span class="gradient-text">アクセス</span>
      </h3>
      <div class="access-grid">
        <div class="access-card">
          <span class="access-icon">🚗</span>
          <h4 class="access-method">お車でお越しの方</h4>
          <p class="access-detail">
            常磐自動車道「広野IC」より約10分。<br>
            会場内に無料駐車場あり（約200台）。<br>
            ※ 混雑時は臨時駐車場をご案内します。
          </p>
        </div>
        <div class="access-card">
          <span class="access-icon">🚃</span>
          <h4 class="access-method">電車でお越しの方</h4>
          <p class="access-detail">
            JR常磐線「竜田駅」下車、車で約10分。<br>
            東京駅から特急ひたちで約2時間半。<br>
            ※ 駅からのシャトルバス運行予定。
          </p>
        </div>
        <div class="access-card">
          <span class="access-icon">🚌</span>
          <h4 class="access-method">バスでお越しの方</h4>
          <p class="access-detail">
            いわき駅前より路線バスで約50分。<br>
            イベント当日は主要駅から<br>
            シャトルバスの運行を予定しています。
          </p>
        </div>
      </div>
      <div class="access-address">
        <p>📮 〒979-0513 福島県双葉郡楢葉町北田天神原30</p>
        <p>🅿️ 無料駐車場あり（約200台）</p>
      </div>
    </div>
  </div>
</section>

<style>
  .venue {
    background: var(--color-white);
    position: relative;
  }

  .venue-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .venue-title {
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    color: var(--color-dark);
    line-height: 1.4;
    margin-bottom: 1rem;
  }

  .venue-location {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1rem;
    color: var(--color-gray-500);
    background: var(--color-gray-100);
    padding: 0.5rem 1.5rem;
    border-radius: var(--radius-pill);
  }

  .venue-map-container {
    margin-bottom: 3rem;
  }

  .venue-map {
    border-radius: var(--radius-card);
    overflow: hidden;
    box-shadow: var(--shadow-card);
  }


  .venue-highlights {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    margin-bottom: 3rem;
  }

  @media (min-width: 768px) {
    .venue-highlights {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }
  }

  @media (min-width: 1024px) {
    .venue-highlights {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .highlight-card {
    background: var(--color-white);
    border-radius: var(--radius-card);
    overflow: hidden;
    box-shadow: var(--shadow-card);
    transition: all 0.3s ease;
  }

  .highlight-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-card-hover);
  }

  .highlight-photo-wrap {
    height: 160px;
    overflow: hidden;
  }

  .highlight-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .highlight-card:hover .highlight-photo {
    transform: scale(1.05);
  }

  .highlight-emoji-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .highlight-emoji-placeholder span {
    font-size: 3.5rem;
    filter: drop-shadow(0 0 12px rgba(255, 200, 50, 0.6));
    animation: emoji-glow 2s ease-in-out infinite alternate;
  }

  @keyframes emoji-glow {
    from { transform: scale(1); }
    to { transform: scale(1.1); }
  }

  .highlight-body {
    padding: 1.25rem 1.25rem 1.5rem;
  }

  .highlight-title {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-dark);
    margin-bottom: 0.5rem;
  }

  .highlight-desc {
    font-size: 0.8rem;
    color: var(--color-gray-500);
    line-height: 1.7;
  }

  /* Synergy Banner */
  .synergy-banner {
    background: linear-gradient(135deg, var(--color-dark), var(--color-dark-soft));
    border-radius: var(--radius-card);
    padding: 2.5rem 2rem;
    position: relative;
    overflow: hidden;
  }

  .synergy-banner::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 300px;
    height: 300px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-sunset), var(--color-ocean));
    opacity: 0.1;
    filter: blur(40px);
  }

  .synergy-content {
    position: relative;
    z-index: 1;
    text-align: center;
  }

  .synergy-badge {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    color: var(--color-ocean-light);
    background: rgba(0, 180, 216, 0.15);
    padding: 0.35rem 1rem;
    border-radius: var(--radius-pill);
    margin-bottom: 1rem;
  }

  .synergy-title {
    font-size: clamp(1.2rem, 3vw, 1.5rem);
    color: var(--color-white);
    margin-bottom: 1rem;
  }

  .synergy-desc {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.8;
    max-width: 600px;
    margin: 0 auto;
  }

  /* Access Section */
  .access-section {
    margin-top: 3rem;
  }

  .access-heading {
    font-size: clamp(1.3rem, 3vw, 1.8rem);
    text-align: center;
    margin-bottom: 2rem;
  }

  .access-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  @media (min-width: 768px) {
    .access-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
  }

  .access-card {
    background: var(--color-sand);
    border-radius: var(--radius-card);
    padding: 1.75rem 1.5rem;
    text-align: center;
    transition: all 0.3s ease;
  }

  .access-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-card);
    background: var(--color-white);
  }

  .access-icon {
    font-size: 2.2rem;
    display: block;
    margin-bottom: 0.75rem;
  }

  .access-method {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-dark);
    margin-bottom: 0.75rem;
  }

  .access-detail {
    font-size: 0.8rem;
    color: var(--color-gray-500);
    line-height: 1.8;
  }

  .access-address {
    text-align: center;
    padding: 1.25rem;
    background: var(--color-gray-100);
    border-radius: var(--radius-card);
  }

  .access-address p {
    font-size: 0.85rem;
    color: var(--color-gray-500);
    line-height: 1.8;
  }
</style>
