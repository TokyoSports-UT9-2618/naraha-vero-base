---

<section id="timetable" class="timetable section-padding">
  <div class="container">
    <div class="tt-header reveal">
      <span class="section-label">TIMETABLE</span>
      <h2 class="tt-title">
        <span class="gradient-text">タイムテーブル</span>
      </h2>
      <p class="tt-lead">2日間のスケジュール</p>
    </div>

    <h3 class="tt-coming-soon reveal">詳細が決まり次第おしらせします</h3>

    <!-- timetable columns (hidden until details are confirmed)
    <div class="tt-columns">
      ...
    </div>
    <p class="tt-note reveal">
      ※ タイムテーブルは予定であり、変更になる場合があります。
    </p>
    -->
  </div>
</section>

<style>
  .timetable {
    background: var(--color-white);
  }

  .tt-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-label {
    display: inline-block;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    color: var(--color-sunset);
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .section-label::before,
  .section-label::after {
    content: '';
    display: inline-block;
    width: 30px;
    height: 1px;
    background: var(--color-sunset);
    vertical-align: middle;
    margin: 0 1rem;
    opacity: 0.5;
  }

  .tt-title {
    font-size: clamp(1.6rem, 4.5vw, 2.8rem);
    color: var(--color-dark);
    line-height: 1.5;
    margin-bottom: 0.5rem;
  }

  .tt-lead {
    font-size: 1rem;
    color: var(--color-gray-500);
  }

  /* 2-column layout */
  .tt-columns {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  @media (min-width: 768px) {
    .tt-columns {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
  }

  .tt-column {
    min-width: 0;
  }

  /* Day header */
  .tt-day-header {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    border-radius: var(--radius-card);
    margin-bottom: 1.5rem;
  }

  .tt-day-header.day1 {
    background: linear-gradient(135deg, var(--color-sunset), var(--color-coral));
  }

  .tt-day-header.day2 {
    background: linear-gradient(135deg, var(--color-ocean-deep), var(--color-ocean));
  }

  .tt-day-date {
    font-family: var(--font-heading);
    font-size: 1.6rem;
    font-weight: 900;
    color: var(--color-white);
    line-height: 1;
  }

  .tt-day-label {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.8);
  }

  /* Timeline */
  .tt-timeline {
    display: flex;
    flex-direction: column;
  }

  .tt-item {
    display: flex;
    align-items: stretch;
    min-height: 52px;
  }

  .tt-time {
    width: 46px;
    flex-shrink: 0;
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-gray-400);
    padding-top: 0.7rem;
    text-align: right;
    padding-right: 0.6rem;
  }

  .tt-dot-wrap {
    width: 18px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
  }

  .tt-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-sunset), var(--color-ocean));
    flex-shrink: 0;
    margin-top: 0.85rem;
    position: relative;
    z-index: 1;
  }

  .tt-line {
    width: 2px;
    flex: 1;
    background: var(--color-gray-200);
  }

  .tt-item:last-child .tt-line {
    display: none;
  }

  .tt-info {
    flex: 1;
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    padding: 0.4rem 0 0.4rem 0.6rem;
    min-width: 0;
  }

  .tt-icon {
    font-size: 1rem;
    flex-shrink: 0;
    margin-top: 0.15rem;
  }

  .tt-item-title {
    font-family: var(--font-heading);
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--color-dark);
    line-height: 1.3;
  }

  .tt-item-desc {
    font-size: 0.7rem;
    color: var(--color-gray-400);
    line-height: 1.4;
    margin-top: 0.1rem;
  }

  /* Hover */
  .tt-item:hover .tt-info {
    background: var(--color-sand);
    border-radius: 8px;
    margin-right: -0.25rem;
    padding-right: 0.25rem;
  }

  .tt-coming-soon {
    text-align: center;
    padding: 3rem 1rem;
    font-family: var(--font-heading);
    font-size: clamp(1.2rem, 3vw, 1.8rem);
    font-weight: 700;
    color: var(--color-gray-400);
    letter-spacing: 0.05em;
  }

  .tt-note {
    text-align: center;
    margin-top: 2.5rem;
    font-size: 0.8rem;
    color: var(--color-gray-400);
  }
</style>
