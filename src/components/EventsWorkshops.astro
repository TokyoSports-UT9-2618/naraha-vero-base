---
const events = [
  {
    icon: '🔥',
    title: '焚き火トークショー',
    time: 'Day1（土）夜',
    desc: 'スペシャルゲストによるトークセッション。旅の経験談やアウトドアライフの魅力を語り合う、焚き火を囲む夜のひととき。',
    tag: 'STAGE',
    tagColor: 'var(--color-sunset)',
  },
  {
    icon: '🎆',
    title: '花火打ち上げ',
    time: 'Day1（土）夜',
    desc: '澄み渡る楢葉の夜空に打ち上がる花火。宿泊キャンプチケット保持者だけが体験できる、海と空に包まれた特別な一夜のフィナーレ。',
    tag: 'SPECIAL',
    tagColor: 'var(--color-ocean)',
  },
  {
    icon: '📷',
    title: 'バイクキャンプスタイル フォトコンテスト',
    time: '随時',
    desc: 'あなたの旅スタイルをシェアしよう。ライドやキャンプのベストショットを応募すると、本部前に張り出されます。NVBならではの思い出を形に。',
    tag: 'EVENT',
    tagColor: 'var(--color-coral)',
  },
  /* 決定次第復活 —— ここからコメントを外す
  {
    icon: '🎒',
    title: 'バイクパッキング講座',
    time: 'Day1 14:00〜',
    desc: '自転車旅の荷物のまとめ方、バッグの選び方をプロが伝授。実際の装備を見ながら学べる実践型講座。',
    tag: 'WORKSHOP',
    tagColor: 'var(--color-sunset)',
  },
  {
    icon: '🏷️',
    title: 'チャリティオークション',
    time: 'Day1 20:00〜',
    desc: '出展ブランド提供の豪華アイテムが登場するチャリティオークション。宿泊者限定の特別イベント。',
    tag: 'EVENT',
    tagColor: 'var(--color-coral)',
  },
  {
    icon: '👶',
    title: 'キッズサイクルスクール',
    time: '両日 10:00〜12:00',
    desc: 'お子さま向けの自転車教室。補助輪を外す練習から安全な乗り方まで、経験豊富なインストラクターが指導。',
    tag: 'KIDS',
    tagColor: '#2D8F4E',
  },
  */
];
---

<section id="events-workshops" class="ew section-padding">
  <div class="container">
    <div class="ew-header reveal">
      <span class="section-label">EVENTS & WORKSHOPS</span>
      <h2 class="ew-title">
        <span class="gradient-text">イベント & ワークショップ</span>
      </h2>
      <p class="ew-lead">
        見て、学んで、体験する。会場内で開催される多彩なプログラム。
      </p>
    </div>

    <div class="ew-grid">
      {events.map((ev, i) => (
        <div class={`ew-card reveal delay-${(i % 3 + 1) * 100}`}>
          <div class="ew-card-top">
            <span class="ew-icon">{ev.icon}</span>
            <span class="ew-tag" style={`--tag-color: ${ev.tagColor}`}>{ev.tag}</span>
          </div>
          <h3 class="ew-card-title">{ev.title}</h3>
          <span class="ew-time">🕐 {ev.time}</span>
          <p class="ew-card-desc">{ev.desc}</p>
        </div>
      ))}
    </div>

    <div class="ew-coming-soon reveal">
      <p class="ew-coming-soon-text">その他のプログラムは決定次第、順次公開していきます。</p>
    </div>

    <p class="ew-note reveal">
      ※ プログラムは変更になる場合があります。最新情報は公式SNSでお知らせします。
    </p>
  </div>
</section>

<style>
  .ew {
    background: var(--color-white);
  }

  .ew-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .section-label {
    display: inline-block;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    color: var(--color-sunset);
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .section-label::before,
  .section-label::after {
    content: '';
    display: inline-block;
    width: 30px;
    height: 1px;
    background: var(--color-sunset);
    vertical-align: middle;
    margin: 0 1rem;
    opacity: 0.5;
  }

  .ew-title {
    font-size: clamp(1.6rem, 4.5vw, 2.8rem);
    color: var(--color-dark);
    line-height: 1.5;
    margin-bottom: 1rem;
  }

  .ew-lead {
    font-size: 1rem;
    color: var(--color-gray-500);
  }

  .ew-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .ew-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .ew-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .ew-card {
    background: var(--color-sand);
    border-radius: var(--radius-card);
    padding: 2rem;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }

  .ew-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 100%;
    background: var(--tag-color, var(--color-sunset));
    border-radius: 4px 0 0 4px;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .ew-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-card);
    background: var(--color-white);
  }

  .ew-card:hover::before {
    opacity: 1;
  }

  .ew-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .ew-icon {
    font-size: 2rem;
  }

  .ew-tag {
    font-family: var(--font-heading);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--tag-color);
    background: color-mix(in srgb, var(--tag-color) 12%, transparent);
    padding: 0.3rem 0.8rem;
    border-radius: var(--radius-pill);
  }

  .ew-card-title {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-dark);
    margin-bottom: 0.5rem;
  }

  .ew-time {
    display: inline-block;
    font-size: 0.75rem;
    color: var(--color-gray-400);
    margin-bottom: 0.75rem;
  }

  .ew-card-desc {
    font-size: 0.85rem;
    color: var(--color-gray-500);
    line-height: 1.8;
  }

  .ew-coming-soon {
    text-align: center;
    margin-top: 2.5rem;
    padding: 1.25rem 2rem;
    background: var(--color-sand);
    border-radius: var(--radius-card);
  }

  .ew-coming-soon-text {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-gray-500);
  }

  .ew-note {
    text-align: center;
    margin-top: 1.5rem;
    font-size: 0.8rem;
    color: var(--color-gray-400);
  }
</style>
