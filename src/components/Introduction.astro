---
const concepts = [
  {
    icon: '🏁',
    title: 'Not a Race',
    description: 'ここでは誰も競いません。焚き火を囲み、今日のライドやこれからの旅について語らう場所です。',
    color: 'var(--color-sunset)',
    image: '/images/about-inclusivity.jpg',
    imageAlt: '焚き火を囲んで語らうBIKE & CAMPの参加者たち',
  },
  {
    icon: '🎵',
    title: 'The Vibe',
    description: '自由でいい。ゆるくていい。それがNVBのスタイルです。時間の流れを忘れさせる心地よさがあります。',
    color: 'var(--color-ocean)',
    image: '/images/about-not-a-race.jpg',
    imageAlt: 'チルな雰囲気のサイクリスト',
  },
  {
    icon: '🤝',
    title: 'Come as You Are',
    description: '自転車に乗る人も乗らない人も、これから始めたい人も。家族や仲間とフラットに楽しめる体験型フェスティバルです。',
    color: 'var(--color-coral)',
    image: '/images/about-the-vibe.jpg',
    imageAlt: 'みんなで楽しむBIKE & CAMPの風景',
  },
];
---

<section id="introduction" class="introduction section-padding">
  <div class="container">
    <div class="intro-header reveal">
      <span class="section-label">ABOUT</span>
      <h2 class="intro-title">
        すべてのサイクリストと<br>旅人が交わる<span class="gradient-text">ベースキャンプ</span>
      </h2>
      <p class="intro-lead">
        ここは「自転車イベント」でも「キャンプイベント」でもありません。<br class="pc-only">
        旅人が集まり、価値観を共有する<strong>「旅イベント」</strong>です。
      </p>
    </div>

    <div class="concepts-grid">
      {concepts.map((concept, i) => (
        <div class={`concept-card reveal delay-${(i + 1) * 100}`} style={`--accent: ${concept.color}`}>
          <div class="concept-image-wrap">
            <img src={concept.image} alt={concept.imageAlt} loading="lazy" class="concept-image" />
            <div class="concept-image-overlay"></div>
            <div class="concept-icon-badge">
              <span class="concept-icon">{concept.icon}</span>
            </div>
          </div>
          <div class="concept-body">
            <h3 class="concept-title">{concept.title}</h3>
            <p class="concept-desc">{concept.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .introduction {
    background: var(--color-sand);
    position: relative;
  }

  .intro-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .intro-title {
    font-size: clamp(1.6rem, 4.5vw, 2.8rem);
    color: var(--color-dark);
    margin-bottom: 1.5rem;
    line-height: 1.5;
  }

  .intro-lead {
    font-size: clamp(0.9rem, 2vw, 1.05rem);
    color: var(--color-gray-500);
    line-height: 2;
    max-width: 700px;
    margin: 0 auto;
  }

  .intro-lead strong {
    color: var(--color-dark);
    font-weight: 600;
  }

  .concepts-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .concepts-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
  }

  .concept-card {
    background: var(--color-white);
    border-radius: var(--radius-card);
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: var(--shadow-card);
    position: relative;
  }

  .concept-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-card-hover);
  }

  .concept-image-wrap {
    position: relative;
    height: 200px;
    overflow: hidden;
  }

  .concept-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .concept-card:hover .concept-image {
    transform: scale(1.08);
  }

  .concept-image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(26, 26, 46, 0.5) 0%, transparent 60%);
  }

  .concept-icon-badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    width: 44px;
    height: 44px;
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(10px);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.1);
  }

  .concept-body {
    padding: 1.75rem 1.75rem;
    border-top: 3px solid var(--accent, var(--color-sunset));
  }

  .concept-title {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-dark);
    margin-bottom: 0.75rem;
    letter-spacing: 0.02em;
  }

  .concept-desc {
    font-size: 0.88rem;
    color: var(--color-gray-500);
    line-height: 1.9;
  }
</style>
